{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Oscahs Training",
  "version": "0.2.2",
  "identifier": "com.oscahs.training",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Oscahs Training Library",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["windows/oscahs-codesign.cer"],
    "windows": {
      "certificateThumbprint": "8032B27ED07EF8879592D3B00C907C541CE64610",
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "./windows/hooks.nsi"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI2QTVFQjhDNkZEMThDMTkKUldRWmpORnZqT3VsSmd3bWIvOVJsNW9YdXlFdXN1UWt6RHhYbEdLUzJSV1I1Ui9BYS9NZklsQTUK",
      "endpoints": [
        "https://github.com/mil0b/Oscahs-Training/releases/latest/download/latest.json"
      ]
    }
  }
}
